# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/

# Distribution / packaging (root-level only)
/dist/
/build/

# Virtual environments (root-level only)
/.venv/
/venv/
/env/
/ENV/

# uv
/.uv/

# pytest / coverage / hypothesis
.pytest_cache/
.coverage
/htmlcov/
.tox/
.hypothesis/

# mypy
.mypy_cache/

# ruff
.ruff_cache/

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Environment / secrets (never commit real credentials)
.env
.env.local
.env.*.local
*.env
# Allow the conventional template file
!.env.example

# Connectors with real credentials (use connectors/*.example.yaml instead)
connectors/*.yaml
!connectors/*.example.yaml

# Logs
*.log
/logs/

# mdBook build output
/docs-build/
