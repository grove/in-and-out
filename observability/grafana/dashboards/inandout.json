      "gridPos": {
        "x": 18,
        "y": 38,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "schema_validation_errors_total",
          "legendFormat": "validation errors",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Reconcile Duration (seconds)",
      "gridPos": {
        "x": 0,
        "y": 42,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(schema_reconcile_duration_seconds_bucket[10m]))",
          "legendFormat": "p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(schema_reconcile_duration_seconds_bucket[10m]))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "DDL Operations (rate by type)",
      "gridPos": {
        "x": 12,
        "y": 42,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(schema_ddl_operations_total[5m])",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Component State Changes (rate by component + state)",
      "gridPos": {
        "x": 0,
        "y": 50,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "expr": "rate(schema_component_state_changes_total[5m])",
          "legendFormat": "{{component}} \u2192 {{state}}",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 18,
      "title": "Federation",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 48
      },
      "panels": []
    },
    {
      "id": 19,
      "title": "Federation Heartbeat Failures (rate)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 49
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(inout_federation_heartbeat_failures_total[5m])",
          "legendFormat": "failures/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "title": "Federation Heartbeat Failures (total)",
      "type": "stat",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 49
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "inout_federation_heartbeat_failures_total",
          "legendFormat": "total failures",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
      "title": "Sesam Dashboard",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 57,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 22,
      "title": "Dashboard HTTP Requests (rate)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 58,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (path, status_code) (rate(dashboard_requests_total{job=\"sesam-dashboard\"}[5m]))",
          "legendFormat": "{{path}} {{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "title": "Dashboard HTTP Latency p95 (seconds)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 58,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (path, le) (rate(dashboard_request_duration_seconds_bucket{job=\"sesam-dashboard\"}[5m])))",
          "legendFormat": "p95 {{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 24,
      "title": "Dashboard Up",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 66,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "up{job=\"sesam-dashboard\"}",
          "legendFormat": "dashboard",
          "refId": "A"
        }
      ]
    },
    {
      "id": 25,
      "title": "Dashboard Total Requests",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 66,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "none"
      },
      "targets": [
        {
          "expr": "sum(dashboard_requests_total{job=\"sesam-dashboard\"})",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 26,
      "type": "row",
      "title": "Webhooks",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 70,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 27,
      "type": "timeseries",
      "title": "Webhook Received Rate (by connector + datatype + status)",
