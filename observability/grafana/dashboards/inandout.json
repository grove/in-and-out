{
  "title": "In-and-Out MDM Sync",
  "uid": "inandout-main",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Records Processed (rate by connector + datatype)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(records_processed_total[5m])",
          "legendFormat": "{{connector}} / {{datatype}} ({{operation}})",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Sync Lag (seconds by connector + datatype)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sync_lag_seconds",
          "legendFormat": "{{connector}} / {{datatype}}",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Circuit Breaker State (by connector + datatype)",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "circuit_breaker_state",
          "legendFormat": "{{connector}} / {{datatype}}",
          "refId": "A",
          "instant": true
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Dead Letter Depth (by connector + datatype)",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "dead_letter_depth",
          "legendFormat": "{{connector}} / {{datatype}}",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Errors (rate by connector)",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(http_errors_total[5m])",
          "legendFormat": "{{connector}} ({{status_code}})",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Simulator",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Simulator API Requests (rate by connector + datatype + method)",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(sim_api_requests_total[5m])",
          "legendFormat": "{{connector}} / {{datatype}} {{method}}",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Simulator Webhook Dispatches (rate by connector + operation)",
      "gridPos": {
        "x": 12,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(sim_webhooks_dispatched_total[5m])",
          "legendFormat": "{{connector}} / {{datatype}} {{operation}}",
          "refId": "A"
        },
        {
          "expr": "rate(sim_webhook_errors_total[5m])",
          "legendFormat": "ERRORS {{connector}} / {{datatype}} {{operation}}",
          "refId": "B"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "Records Stored in Simulator (by connector + datatype)",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "expr": "sim_records_stored",
          "legendFormat": "{{connector}} / {{datatype}}",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Schema Manager",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Reconcile Cycles",
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 6,
        "h": 4
