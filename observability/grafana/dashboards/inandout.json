      "targets": [
        {
          "expr": "increase(schema_reconcile_total{result=\"success\"}[1h])",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "expr": "increase(schema_reconcile_total{result=\"error\"}[1h])",
          "legendFormat": "error",
          "refId": "B"
        },
        {
          "expr": "increase(schema_reconcile_total{result=\"skipped\"}[1h])",
          "legendFormat": "skipped",
          "refId": "C"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 12,
      "type": "gauge",
      "title": "Stream Tables Managed",
      "gridPos": {
        "x": 6,
        "y": 38,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "schema_stream_tables",
          "legendFormat": "stream tables",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Leader",
      "gridPos": {
        "x": 12,
        "y": 38,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "schema_leader",
          "legendFormat": "leader lock held",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      }
    },
    {
      "id": 14,
      "type": "stat",
