{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inout.dev/schemas/profiles/ingestion_polling_readonly.schema.json",
  "allOf": [
    {
      "$ref": "../connector.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "connector": {
          "type": "object",
          "required": [
            "generation_profile",
            "datatypes"
          ],
          "properties": {
            "generation_profile": {
              "const": "ingestion_polling_readonly"
            },
            "datatypes": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "object",
                "required": [
                  "ingestion"
                ],
                "properties": {
                  "ingestion": {
                    "$ref": "../defs/ingestion.schema.json"
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}