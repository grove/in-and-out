{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inout.dev/schemas/defs/writeback.schema.json",
  "title": "Writeback Datatype",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "protection_level",
    "conflict_resolution",
    "supported_actions",
    "operations"
  ],
  "properties": {
    "protection_level": {
      "type": "integer",
      "enum": [
        1,
        2,
        3
      ]
    },
    "conflict_resolution": {
      "type": "string",
      "enum": [
        "dead_letter",
        "last_writer_wins",
        "skip_and_warn",
        "re_ingest_and_recompute"
      ]
    },
    "supported_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "depends_on"
        ],
        "properties": {
          "depends_on": {
            "type": "string"
          }
        }
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "lookup"
      ],
      "properties": {
        "lookup": {
          "$ref": "#/$defs/operation"
        },
        "insert": {
          "$ref": "#/$defs/operation"
        },
        "update": {
          "allOf": [
            {
              "$ref": "#/$defs/operation"
            },
            {
              "type": "object",
              "properties": {
                "conditional_write": {
                  "type": "object",
                  "required": [
                    "enabled"
                  ],
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "header": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          ]
        },
        "delete": {
          "$ref": "#/$defs/operation"
        },
        "archive": {
          "$ref": "#/$defs/operation"
        },
        "upsert": {
          "$ref": "#/$defs/operation"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "protection_level": {
            "const": 1
          }
        }
      },
      "then": {
        "properties": {
          "operations": {
            "required": [
              "update"
            ],
            "properties": {
              "update": {
                "required": [
                  "conditional_write"
                ],
                "properties": {
                  "conditional_write": {
                    "properties": {
                      "enabled": {
                        "const": true
                      }
                    },
                    "required": [
                      "enabled"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "operation": {
      "type": "object",
      "required": [
        "method",
        "path"
      ],
      "properties": {
        "method": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    }
  }
}