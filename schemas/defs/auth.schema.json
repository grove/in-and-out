{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inout.dev/schemas/defs/auth.schema.json",
  "title": "Authentication",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "credential_ref"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "oauth2",
        "api_key",
        "jwt",
        "custom"
      ]
    },
    "credential_ref": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "oauth2": {
      "type": "object",
      "required": [
        "grant_type",
        "token_url"
      ],
      "properties": {
        "grant_type": {
          "type": "string",
          "enum": [
            "authorization_code",
            "client_credentials"
          ]
        },
        "token_url": {
          "type": "string"
        },
        "refresh_url": {
          "type": "string"
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "token_injection": {
          "type": "object"
        }
      }
    },
    "api_key": {
      "type": "object",
      "required": [
        "location",
        "name"
      ],
      "properties": {
        "location": {
          "type": "string",
          "enum": [
            "header",
            "query"
          ]
        },
        "name": {
          "type": "string"
        }
      }
    },
    "jwt": {
      "type": "object",
      "required": [
        "algorithm",
        "issuer",
        "audience"
      ],
      "properties": {
        "algorithm": {
          "type": "string"
        },
        "issuer": {
          "type": "string"
        },
        "audience": {
          "type": "string"
        },
        "expiry": {
          "type": "integer",
          "minimum": 1
        },
        "claims": {
          "type": "object"
        },
        "token_injection": {
          "type": "object"
        }
      }
    },
    "custom": {
      "type": "object",
      "required": [
        "steps",
        "inject"
      ],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object"
          }
        },
        "inject": {
          "type": "object"
        },
        "refresh": {
          "type": "object"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "oauth2"
          }
        }
      },
      "then": {
        "required": [
          "oauth2"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "api_key"
          }
        }
      },
      "then": {
        "required": [
          "api_key"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "jwt"
          }
        }
      },
      "then": {
        "required": [
          "jwt"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "custom"
          }
        }
      },
      "then": {
        "required": [
          "custom"
        ]
      }
    }
  ]
}